# Development/integration-test credentials. Never commit a populated .env file.
FRESHRSS_API_URL=https://reader.example/api/greader.php
FRESHRSS_USERNAME=your-username
FRESHRSS_API_PASSWORD=your-freshrss-api-password
# Set to 1 only when a live FreshRSS server should be contacted by the tests.
FRESHRSS_LIVE_TEST=0
